{
  "name": "rugby-analysis-suite",
  "private": true,
  "version": "1.3.2",
  "description": "Professional Rugby Analysis and Compilation Software",
  "author": "JD Gouws",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron": "electron electron/main.cjs",
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron\"",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.rugbysuite.analysis",
    "productName": "Rugby Analysis Suite",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      "build/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "jdgouws10-coder",
        "repo": "rugby-analysis-suite"
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "Rugby-Analysis-Suite-Setup.exe",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Rugby Analysis Suite"
    }
  },
  "dependencies": {
    "concurrently": "^10.0.3",
    "electron-updater": "^6.6.2",
    "ffmpeg-static": "^5.3.0",
    "jspdf": "^4.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "wait-on": "^9.0.10"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
